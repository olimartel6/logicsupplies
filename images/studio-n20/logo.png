	$(document).ready(function(){
    if ($(window).width() <= 600) {
        $(".scroll-bottom").on('click', function(event) {
            event.preventDefault();

            $('html, body').animate({
                scrollTop: 2060
            }, 800);
        });
    }
});
	
		$(document).ready(function(){
    if ($(window).width() <= 780 && $(window).width() >= 601) {
        $(".scroll-bottom").on('click', function(event) {
            event.preventDefault();

            $('html, body').animate({
                scrollTop: 1760
            }, 800);
        });
    }
});
	
